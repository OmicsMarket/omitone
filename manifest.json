{
  "manifest_version": 3,
  "name": "欧米通",
  "version": "1.0.1",
  "description": "欧米通 — 稳定版：视频正常倍速播放 + AI自动答题 + 纯文本秒跳，无拖动跳过",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "欧米通",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chaoxing.com/mycourse/*",
        "*://mooc1.chaoxing.com/mycourse/*",
        "*://*.chaoxing.com/mooc2-ans/mycourse/*",
        "*://*.chaoxing.com/ananas/modules/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["*://*.chaoxing.com/*"]
    }
  ],
  "host_permissions": [
    "*://*.chaoxing.com/*"
  ]
}
